{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    %% v1.4.26 is the first hex release with macula_dist_relay_client
    %% + macula_dist_relay_protocol — required by the CT suite and by
    %% anyone integrating the dist relay from client code.
    {macula, "~> 1.4.26"}
]}.

{shell, [
    {apps, [macula_dist_relay]}
]}.

{eunit_opts, [verbose]}.

{relx, [
    {release, {macula_dist_relay, "0.1.0"}, [
        macula_dist_relay,
        sasl
    ]},
    {mode, dev},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_src, false}
        ]}
    ]}
]}.
