{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    %% 3.0.0 = CBOR wire format. Wire-incompatible with 2.x and 1.x.
    %% Dist-over-relay's stream-0 control frames are CBOR now;
    %% tunnel streams are still raw bytes (no encoding).
    %% 3.6.0 vendored macula_frame; 3.7.0 vendored macula_peering.
    {macula, "~> 3.7"}
]}.

{shell, [
    {apps, [macula_dist_relay]}
]}.

{eunit_opts, [verbose]}.

{relx, [
    {release, {macula_dist_relay, "0.1.0"}, [
        macula_dist_relay,
        sasl
    ]},
    {mode, dev},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_src, false}
        ]}
    ]}
]}.
