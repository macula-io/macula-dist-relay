{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    %% v1.4.29 ships the dist-over-relay handshake fixes (packet framing,
    %% inbound handoff drain, dist controller loop). Anything below 1.4.29
    %% on this code path returns pang on the first net_adm:ping.
    {macula, "~> 1.4.29"}
]}.

{shell, [
    {apps, [macula_dist_relay]}
]}.

{eunit_opts, [verbose]}.

{relx, [
    {release, {macula_dist_relay, "0.1.0"}, [
        macula_dist_relay,
        sasl
    ]},
    {mode, dev},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_src, false}
        ]}
    ]}
]}.
