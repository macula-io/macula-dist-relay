{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    %% v1.4.30 adds the post-handshake leftover-buffer seed that makes
    %% dist-over-relay survive WAN latency. 1.4.29 shipped the packet
    %% framing + controller loop but truncated the first post-nodeup
    %% frame when peer bytes merged into one QUIC event (~50 ms RTT).
    {macula, "~> 1.4.30"}
]}.

{shell, [
    {apps, [macula_dist_relay]}
]}.

{eunit_opts, [verbose]}.

{relx, [
    {release, {macula_dist_relay, "0.1.0"}, [
        macula_dist_relay,
        sasl
    ]},
    {mode, dev},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_src, false}
        ]}
    ]}
]}.
