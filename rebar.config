{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    %% 3.0.0 = CBOR wire format. Wire-incompatible with 2.x and 1.x.
    %% Dist-over-relay's stream-0 control frames are CBOR now;
    %% tunnel streams are still raw bytes (no encoding).
    %% 3.6.0 vendored macula_frame; 3.7.0 vendored macula_peering.
    %% 3.16.0 = pool RPC + status/1 + subscribe_callback/4 (additive,
    %%          no impact on dist tunnel hot path).
    {macula, "~> 4.0.0"}
]}.

{shell, [
    {apps, [macula_dist_relay]}
]}.

{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [ #{files => ["src/**/*.erl"], ruleset => macula_min} ]}
]}.

{eunit_opts, [verbose]}.

{relx, [
    {release, {macula_dist_relay, "0.1.0"}, [
        macula_dist_relay,
        sasl
    ]},
    {mode, dev},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {dev_mode, false},
            {include_src, false}
        ]}
    ]},
    {lint, [
        {plugins, [{rebar3_lint, "5.0.4"}]}
    ]}
]}.
